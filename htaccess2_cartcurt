Options +FollowSymLinks -MultiViews
RewriteEngine On

# PROJENİN ÇALIŞTIĞI KLASÖRÜ BURAYA TANIMLIYORUZ
RewriteBase /cari_takip/

# 1. ADIM: Eğer birisi tarayıcıya 'anasayfa.php' yazarsa, onu 'anasayfa' adresine yönlendir (Güzellik için)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. ADIM: Eğer girilen adres bir dosya veya klasör DEĞİLSE, sonuna .php ekleyip çalıştırmayı dene.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]